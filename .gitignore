# MSBrossAI/.gitignore
# Comprehensive .gitignore for MSBrossAI ecosystem

# Environment files
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
.env.vault
.env*.vault
.env*.key

# Credential files
*.pem
*.key
*.crt
*.cer
*.pfx
*.p12
*.der
*.csr
*.pub

# Token files
*.token
*.jwt
*.secret

# Database files
*.db
*.sqlite
*.sqlite3
*.mdb
*.accdb
*.frm
*.ibd
*.myd
*.myi
*.h2.db
*.mv.db
*.trace.db

# Log files
*.log
logs/
*.log.*
npm-debug.log*

# Build artifacts
build/
dist/
target/
out/
bin/
obj/
*.exe
*.dll
*.so
*.dylib
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv/
.env/

# Dependency directories
jspm_packages/

# Test coverage
coverage/
*.lcov

# Miscellaneous
*.bak
*.tmp
*.swp
*.orig
*.rej
*.manifest
*.cache
*.stackdump
*.pid
*.seed
*.pid.lock

# Dotenv Vault
.env.vault
.env.me

# Security audit files
*.key
*.vault
*.enc

# Ignore all .env files in subdirectories
**/.env
**/.env.*

# Ignore all credential files in subdirectories
**/*.pem
**/*.key
**/*.crt
**/*.cer
**/*.pfx
**/*.p12
**/*.der
**/*.csr
**/*.pub