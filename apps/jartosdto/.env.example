# ═══════════════════════════════════════════════════════════
# JartosDTo — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── General ──────────────────────────────────────────────
NODE_ENV=development
APP_NAME=JartosDTo
APP_URL=http://localhost:3100
API_URL=http://localhost:8100

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string
NEXTAUTH_SECRET=change-me-to-a-random-64-char-string
NEXTAUTH_URL=http://localhost:3100
ADMIN_EMAIL=admin@jartosdto.local
ADMIN_PASSWORD=changeme

# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5433
POSTGRES_USER=jartosdto
POSTGRES_PASSWORD=jartosdto_secret
POSTGRES_DB=jartosdto
DATABASE_URL=postgresql+asyncpg://jartosdto:jartosdto_secret@postgres:5433/jartosdto

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6380
REDIS_URL=redis://redis:6380/0

# ── MinIO (S3-compatible file storage) ───────────────────
MINIO_ROOT_USER=jartosdto
MINIO_ROOT_PASSWORD=jartosdto_secret
MINIO_ENDPOINT=minio:9010
MINIO_BUCKET=uploads

# ── LLM Provider API Keys ───────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=

# ── Local Model Runners ─────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
VLLM_BASE_URL=http://host.docker.internal:8001
LMSTUDIO_BASE_URL=http://host.docker.internal:1234

# ── Web Search ───────────────────────────────────────────
TAVILY_API_KEY=
SEARXNG_BASE_URL=http://searxng:8080

# ── Code Sandbox ─────────────────────────────────────────
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT_MB=256

# ── Embeddings ───────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
