# ============================================================================
# CuentosMagicos AI - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------------------------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_SECRET_KEY=your-app-secret-key-here

# ----------------------------------------------------------------------------
# DATABASE (PostgreSQL - Supabase or local)
# ----------------------------------------------------------------------------
# For local PostgreSQL:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cuentos_magicos
# For Supabase:
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Supabase Configuration
SUPABASE_URL=your-supabase-url-here
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_KEY=your-supabase-service-key-here

# ----------------------------------------------------------------------------
# REDIS (for Celery task queue)
# ----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ----------------------------------------------------------------------------
# OPENAI API (Text generation, DALL-E 3 images, TTS audio)
# ----------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL_STORY=gpt-4o-2024-11-20
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_SPEED=0.9

# ----------------------------------------------------------------------------
# ALTERNATIVE: Google AI Studio (Gemini)
# ----------------------------------------------------------------------------
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-2.0-flash

# ----------------------------------------------------------------------------
# ALTERNATIVE: Groq
# ----------------------------------------------------------------------------
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ----------------------------------------------------------------------------
# ALTERNATIVE: OpenRouter
# ----------------------------------------------------------------------------
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ----------------------------------------------------------------------------
# ALTERNATIVE: Mistral
# ----------------------------------------------------------------------------
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=mistral-small-latest

# ----------------------------------------------------------------------------
# ALTERNATIVE: MiniMax
# ----------------------------------------------------------------------------
MINIMAX_API_KEY=your-minimax-api-key-here

# ----------------------------------------------------------------------------
# IMAGE GENERATION
# ----------------------------------------------------------------------------
IMAGE_PROVIDER=openai

# Alternative: FAL.AI (Stable Diffusion, FLUX)
FAL_AI_KEY=your-fal-ai-key-here

# Alternative: Hugging Face
HUGGINGFACE_TOKEN=your-huggingface-token-here

# Alternative: ComfyUI
COMFYUI_API_KEY=your-comfyui-api-key-here

# ----------------------------------------------------------------------------
# VIDEO GENERATION
# ----------------------------------------------------------------------------
LUMA_API_KEY=your-luma-api-key-here
RUNWAY_API_KEY=your-runway-api-key-here
STABILITY_AI_KEY=your-stability-ai-key-here

# ----------------------------------------------------------------------------
# FILE STORAGE (Supabase Storage)
# ----------------------------------------------------------------------------
STORAGE_PROVIDER=supabase
STORAGE_BUCKET=cuentos-magicos
STORAGE_PUBLIC_URL=your-supabase-storage-public-url-here

# Alternative: AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key-here
AWS_S3_BUCKET=your-aws-bucket-name-here
AWS_S3_REGION=us-east-1

# ----------------------------------------------------------------------------
# MODERATION / SAFETY
# ----------------------------------------------------------------------------
MODERATION_PROVIDER=openai
MODERATION_MODEL=omni-moderation-latest

# ----------------------------------------------------------------------------
# FRONTEND (Next.js)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ----------------------------------------------------------------------------
# TIER CONFIGURATION
# ----------------------------------------------------------------------------
TIER_FREE_MAX_CHAPTERS=3
TIER_FREE_IMAGE_SIZE=768x768
TIER_FREE_VIDEO_ENABLED=false
TIER_PRO_MAX_CHAPTERS=5
TIER_PRO_IMAGE_SIZE=1024x1024
TIER_PRO_VIDEO_ENABLED=true
TIER_ENTERPRISE_MAX_CHAPTERS=8
TIER_ENTERPRISE_IMAGE_SIZE=1024x1792
TIER_ENTERPRISE_VIDEO_ENABLED=true

# ----------------------------------------------------------------------------
# LOGGING
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

