# LIVEKIT Nikolina - Environment Variables
# Copy to .env and fill in real values

# === LiveKit ===
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_PUBLIC_URL=wss://livekit.alvarezconsult.com
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# === Server ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# === CORS (comma-separated origins) ===
CORS_ORIGINS=https://livekit.alvarezconsult.com,http://localhost:5173,http://localhost:5174

# === Google (Gemini) ===
GOOGLE_API_KEY=

# === Microsoft (Hotmail) ===
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
HOTMAIL_USER=

# === Tavily (web search) ===
TAVILY_API_KEY=

# === Monitoring ===
SENTRY_DSN=

# === Admin (for dashboard login) ===
ADMIN_USERNAME=
ADMIN_PASSWORD=

# === JWT Secret ===
JWT_SECRET=
