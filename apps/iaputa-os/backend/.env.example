# IAPuta OS Backend - Environment Variables
# Copy to .env and fill in real values

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8000

# === CORS (comma-separated origins, * for all) ===
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# === AI Providers ===
GROQ_API_KEY=
TAVILY_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_API_KEY_2=
OPENROUTER_API_KEY_3=

# === API Authentication ===
IAPUTA_API_KEY=

# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# === Microsoft (Hotmail) ===
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
HOTMAIL_USER=

# === Google Workspace ===
GOOGLE_PROJECT_ID=
GOOGLE_STUDIO_API_KEY=

# === Monitoring ===
SENTRY_DSN=
