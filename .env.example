# =============================================================================
# MSBrossAI — Global Environment Variables
# =============================================================================
# Copy to .env in each app directory as needed.
#
# Architecture:
#   nominalia (msbross.me) -> static HTML/SPA
#   Mac (localhost:8080)   -> proxy.js + all backends
#   Cloudflare Tunnel     -> exposes Mac:8080 to internet
#   LiveKit Cloud         -> WebRTC signaling
# =============================================================================

# ─── LIVEKIT (Cloud) ─────────────────────────────────────────────────────────
# Used by: livekit-nikolina/server + atenea-backend
# URL and credentials for LiveKit Cloud (wss://*.livekit.cloud)
LIVEKIT_URL=wss://nikolina-1jg7t00i.livekit.cloud
LIVEKIT_API_KEY=APImFaaEbrWeQic
LIVEKIT_API_SECRET=QS1TLFFpTIIjyY39erfWy71fomgygJnhIYspScwURLgB

# ─── GOOGLE AI ────────────────────────────────────────────────────────────────
# Used by: livekit-nikolina (agent), nikolina-server
# Gemini API key for real-time audio voice agent
GOOGLE_API_KEY=AIzaSy...

# ─── NIKOLINA SERVER (port 8001) ──────────────────────────────────────────────
# Used by: livekit-nikolina/server/.env
PORT=8001
JWT_SECRET=MSBROSS_SECRET_TOKEN_2026
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
CORS_ORIGINS="https://msbross.me,https://*.trycloudflare.com,http://localhost:5173"

# ─── ATENEA BACKEND (port 8009) ──────────────────────────────────────────────
# Used by: apps/atenea-backend/.env
# If empty, auto-negotiates based on request protocol:
#   HTTPS -> wss://{host}/rtc
#   HTTP  -> ws://localhost:7880
LIVEKIT_URL=ws://localhost:7880

# ─── FRONTEND ENV (Nikolina Vite app) ─────────────────────────────────────────
# Set at BUILD TIME in apps/livekit-nikolina/frontend/.env.production
# When empty, app defaults:
#   API_BASE     -> /_nikolina/api (relative, through proxy.js)
#   LIVEKIT_URL  -> wss://{host}/rtc (for self-hosted)
#                     OR wss://nikolina-1jg7t00i.livekit.cloud (for Cloud)
VITE_LIVEKIT_URL=wss://nikolina-1jg7t00i.livekit.cloud
VITE_API_BASE_URL=/_nikolina/api

# ─── OTHER APPS ───────────────────────────────────────────────────────────────
# iaputa-os/frontend/.env.production
VITE_API_BASE_URL=/_iaputa/api

# traductor-pro/client/.env.production
VITE_API_BASE=/_arantxa

# =============================================================================
# DEPLOYMENT
# =============================================================================
# FTP credentials for nominalia (deploy/ftp-deploy-full.py)
FTP_HOST=msbros.ftp.tb-hosting.com
FTP_USER=msbrossme@msbrossme
FTP_PASSWORD=your_password_here

# Cloudflare Tunnel (deploy/tunnel.sh)
# Installed via: brew install cloudflared
